// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

datasource db {
  provider = "postgresql"
}

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

model User {
  id             String       @id @default(cuid())
  name           String
  email          String       @unique
  password       String
  rootDir        String       @default("")
  role           String       @default("U")
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  shares         Share[]      @relation("OwnedShares")
  receivedShares Share[]      @relation("ReceivedShares")
  tags           Tag[]
  fileTags       FileTag[]
  createdApps    App[]        @relation("CreatedApps")
  appTokens      AppToken[]
  dataRecords    DataRecord[]
}

model Setting {
  id    String @id @unique
  value String
}

model InviteLink {
  id        String   @id @default(cuid())
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
  rootDir   String   @default("")
  role      String   @default("U")
}

model Share {
  id           String    @id @default(cuid())
  token        String    @unique @default(cuid())
  name         String
  path         String
  fileType     String
  access       String
  ownerId      String
  recipientId  String?
  ownerRootDir String    @default("")
  expiresAt    DateTime?
  maxReads     Int?
  readCount    Int       @default(0)
  createdAt    DateTime  @default(now())
  owner        User      @relation("OwnedShares", fields: [ownerId], references: [id], onDelete: Cascade)
  recipient    User?     @relation("ReceivedShares", fields: [recipientId], references: [id], onDelete: SetNull)
}

model Tag {
  id        String    @id @default(cuid())
  name      String
  color     String
  ownerId   String
  createdAt DateTime  @default(now())
  owner     User      @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  fileTags  FileTag[]

  @@unique([ownerId, name])
}

model FileTag {
  id        String   @id @default(cuid())
  path      String
  ownerId   String
  tagId     String
  createdAt DateTime @default(now())
  owner     User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  tag       Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([ownerId, path, tagId])
}

model App {
  id            String       @id @default(cuid())
  name          String
  slug          String       @unique
  description   String?
  developerName String?
  clientId      String       @unique
  enabled       Boolean      @default(true)
  createdById   String
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  createdBy     User         @relation("CreatedApps", fields: [createdById], references: [id], onDelete: Cascade)
  datasets      AppDataset[]
  tokens        AppToken[]
  records       DataRecord[]
}

model AppDataset {
  id        String       @id @default(cuid())
  appId     String
  name      String
  kind      String
  schema    Json
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  app       App          @relation(fields: [appId], references: [id], onDelete: Cascade)
  records   DataRecord[]

  @@unique([appId, name])
}

model AppToken {
  id        String    @id @default(cuid())
  appId     String
  userId    String
  tokenHash String    @unique
  name      String
  scopes    String[]
  expiresAt DateTime?
  revokedAt DateTime?
  createdAt DateTime  @default(now())
  app       App       @relation(fields: [appId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model DataRecord {
  id        String     @id @default(cuid())
  appId     String
  datasetId String
  ownerId   String
  key       String?
  value     Json
  version   Int        @default(1)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  deletedAt DateTime?
  app       App        @relation(fields: [appId], references: [id], onDelete: Cascade)
  dataset   AppDataset @relation(fields: [datasetId], references: [id], onDelete: Cascade)
  owner     User       @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  @@unique([appId, datasetId, ownerId, key])
  @@index([appId, datasetId, ownerId])
}
